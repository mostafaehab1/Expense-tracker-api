# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Server
NODE_ENV=development
PORT=4000

# MongoDB connection string.
# Local docker-compose default is shown below; override for Atlas/prod.
MONGODB_URI=mongodb://localhost:27017/expense_tracker

# JWT signing. Use a long random string in production (e.g. `openssl rand -hex 32`).
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# bcrypt work factor (higher = slower = more secure). 12 is a sensible default.
BCRYPT_ROUNDS=12
